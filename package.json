{
  "name": "wechat-claude-code-windows",
  "version": "1.0.0",
  "description": "Chat with Claude Code from WeChat on Windows - a Claude Code Skill that bridges personal WeChat to local Claude Code",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "postinstall": "npm run build",
    "start": "node dist/main.js",
    "run": "node dist/main.js start",
    "dev": "tsc --watch",
    "test": "node --test dist/tests/*.test.js",
    "setup": "node dist/main.js setup",
    "daemon": "powershell -ExecutionPolicy Bypass -File scripts/daemon.ps1",
    "visualize": "npx tsx src/tools/visualize-logs.ts"
  },
  "dependencies": {
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/qrcode-terminal": "^0.12.0",
    "typescript": "^5.7.0"
  },
  "keywords": ["wechat", "claude-code", "claude", "bridge", "chat", "skill", "windows"],
  "author": "faruhe·aisha (forked from Wechat-ggGitHub)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/faruheaisha/wechat-claude-code-windows.git"
  }
}
